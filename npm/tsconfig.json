{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "agent-ads/**/*.ts",
    "platform/**/*.ts"
  ]
}
