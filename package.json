{
  "name": "agent-ads-workspace",
  "private": true,
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "build:ts": "tsc -p npm/tsconfig.json",
    "build:npm": "npm run build:ts && node npm/agent-ads/scripts/prepare-release.js",
    "docs:generate": "npm run build:ts && node npm/agent-ads/scripts/generate-command-topics.js",
    "release:publish": "npm run build:ts && node npm/agent-ads/scripts/publish-release.js",
    "release:trust": "npm run build:ts && node npm/agent-ads/scripts/configure-trusted-publishing.js",
    "test:smoke": "npm run build:ts && node npm/agent-ads/bin/agent-ads.js --version"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "typescript": "^5.8.2"
  }
}
